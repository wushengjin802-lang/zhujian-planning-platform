{
  "name": "@zhujian/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "db:check": "tsx src/scripts/check-db.ts",
    "db:ensure": "tsx src/scripts/ensure-db.ts",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@zhujian/shared": "0.1.0",
    "cors": "^2.8.5",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.6"
  }
}
